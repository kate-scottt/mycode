source("https://edin.ac/4boOrMs")
get_my_data("B280847")
library(tidyverse)
library(lme4)

#Part A : Garden Path 
head(gardenpath)
summary(gardenpath)
length(unique(gardenpath$participant))
#doing some cleaning
#some things are characters and they shouldn't be
gardenpath$participant <- as.factor(gardenpath$participant)
gardenpath$allotment <- as.factor(gardenpath$allotment)
#gtype says theres 3 levels in the q but theres 5 in the data = recode to 3 categories?
#no that made everything into NAs and i had to reload the data - The gardening type variable would be inspected prior to recoding to ensure all levels are correctly understood. Incorrect specification of factor levels can result in unintended missing values. Any unexpected categories would be investigated and either recoded appropriately or excluded based on the study design.
table(gardenpath$gtype)
#why 14 5s - The gardening type variable contains an unexpected category (coded as 5) with a very small number of observations. This would be investigated and, if confirmed as an error or irrelevant category, excluded from the analysis.
#just remove in case its an error?
gardenpath <- subset(gardenpath, gtype %in% c(1,2,3))
#recode to labels instead of numbers so that R doesn't accidentally group them higher because theyre numeric? -Categorical predictors should be coded as factors to ensure they are treated as nominal variables rather than continuous numeric variables, allowing for appropriate estimation and interpretation of group differences.
gardenpath$gtype <- factor(gardenpath$gtype,
                           levels = c(1,2,3),
                           labels = c("paired", "community", "solitary"))
#relevel so that solitary is the baseline - The categorical predictor would be relevelled to set a meaningful reference category (e.g., solitary gardening), allowing comparisons of paired and group conditions relative to a baseline condition.
gardenpath$gtype <- relevel(gardenpath$gtype, ref = "solitary")
#check RSES values
summary(gardenpath$RSES)
# max 36 - this is outside the rses range 
#identify bad variables - only 3 - A small number of values exceeded the theoretical range of the RSES (0–30), indicating likely data entry or scoring errors. These values were set to missing to avoid distortion of model estimates, and handled using the mixed model’s capacity to accommodate missing outcome data.
sum(gardenpath$RSES > 30, na.rm = TRUE)
gardenpath$RSES[gardenpath$RSES > 30] <- NA
#concerned about the NAs - check pattern
table(is.na(gardenpath$RSES))
aggregate(RSES ~ time, data = gardenpath, function(x) sum(is.na(x)))
#Inspection of missing data patterns indicated no increase in missingness over time, suggesting the absence of systematic dropout. Therefore, the assumption that data are missing at random is reasonable. the model can delete them randomly so no need to get rid
#anyway the max age looks weird 
sum(gardenpath$age > 25)
#its only 7, do the same thing as we did for the bad variables in RSES
gardenpath$age[gardenpath$age > 25] <- NA
#missing data? - The extent of missing data was assessed to determine whether it was substantial enough to bias results. (it wasn't)
sum(is.na(gardenpath$RSES))
#recentering age - 12 - 25 and R would have automatically started from 0, reduces collinearity
gardenpath$age_c <- scale(gardenpath$age, center = TRUE, scale = FALSE)
#does g type vary within participants? no
table(gardenpath$participant, gardenpath$gtype)

#visualising mean self esteem over time depending on groups - check previous project for the code for this also - the lines touch - does that mean theres an interaction also steep incline after 15 months
library(ggplot2)

ggplot(gardenpath, aes(x = months, y = RSES, colour = gtype)) +
  stat_summary(fun = mean, geom = "line", size = 1.2) +
  stat_summary(fun = mean, geom = "point") +
  labs(x = "Months", y = "Self-esteem (RSES)",
       colour = "Gardening type") +
  theme_minimal()
save.image("my_workspace.RData")
#linear vs quadratic model - these are both exploratory: no random slopes etc so might not even need to be in the final draft of code
linearmod1 <- lmer(RSES ~ months * gtype + (1 | participant),
     data = gardenpath)
#fitting a quadratic model

quadmod_poly <- lmer(RSES ~ poly(months, 2, raw = TRUE) * gtype +
                       (1 | participant),
                     data = gardenpath)
#comparing
anova(linearmod1, quadmod_poly)
#it says that quad is significant
summary(quadmod_poly)

#so idk if this is right but when doing an anova on some models they wont work because theyre not all fitted to the same dataset i.e. because there are NAs and R drops them automatically, different models are using different data (?) so need a dataset that removes the nas in those variables only
library(dplyr)

gardenpath_complete <- gardenpath %>%
  filter(complete.cases(RSES, months, gtype, age_c, prevexp))
#model
fullmodel <- lmer(RSES ~ poly(months, 2, raw = TRUE) * gtype +
                    age_c + prevexp +
                    (1 + months | participant) +
                    (1 | allotment),
                  data = gardenpath_complete)
#it wasnt converging so i did this but idk need to check bobyqa
fullmodel <- lmer(
  RSES ~ poly(months, 2, raw = TRUE) * gtype +
    age_c + prevexp +
    (1 + months | participant) +
    (1 | allotment),
  data = gardenpath_complete,
  control = lmerControl(optimizer = "bobyqa")
)



#visualising
ggplot(gardenpath, aes(x = months, y = RSES, colour = gtype)) +
  geom_point(alpha = 0.2) +
  stat_smooth(method = "lm",
              formula = y ~ poly(x, 2),
              se = FALSE) +
  theme_minimal()
library(ggeffects)

pred <- ggpredict(fullmodel, terms = c("months", "gtype"))

plot(pred)
