anova(nocovmod, fullmodel)
#didn't converge (?) because age_C had missing values because i had 7 NAs earlier so full model dropped the rows but nocov mod didn't // tried it again and it was fine

# allotment random effects - do allotments matter? = yes
noallotmod <- lmer(RSES ~ poly(months, 2, raw = TRUE) * gtype +
                       age_c + prevexp +
                       (1 + months | participant),
                     data = gardenpath_complete)
#there was a converge warning here but idk if its important as this isnt the final model anyway
anova(noallotmod, fullmodel)

##final models
fullmodel3 <- lmer(RSES ~ poly(months, 2, raw = TRUE) * gtype +
                     age_c + prevexp +
                     (1 + months | participant) +
                     (1 | allotment),
                   data = gardenpath_complete)

#to find out what optimiser to use
allFit(fullmodel3)

#final model w optimiser and allotment nested in participant to look at self esteem of people within allotments

fullmodel_final <- lmer(
  RSES ~ poly(months,2,raw=TRUE)*gtype +
    age_c + prevexp +
    (1 + months | allotment) +
    (1 + months | allotment:participant),
  data = gardenpath_complete, control = lmerControl(optimizer="bobyqa")
)

summary(fullmodel_final)
