library(lavaan)
library(lme4)
library(tidyverse)
library(psych)
library(GPArotation)
library(car)
#checking 
summary(locus)
##ASSUMPTIONS
#check if any IDs are duplicated, and anything outside of the Likert scale//checking univariate normality 
psych::describe(locus)
#check that they are all 1-5
apply(locus[, -1], 2, function(x) range(x, na.rm = TRUE))
#something chat told me to do idk
table(locus$loc4, useNA="ifany")
table(locus$cope3, useNA="ifany")
#reverse coding - loc4 it is just luck (6 item), cope3 when i have a problem (8 item), six becasue its a 5 point scale of measurement 
locus <- locus |>
  mutate(
    loc4r = 6 - loc4,
    cope3r = 6 - cope3
  )

#separate CFAs 
#PCA not necessary because this is theory 
#before we think about theory, think about the measurement models for each of the constructs we are trying to capture. Test separate one-factor models for each construct. Are the measurement models satisfactory? (checking fit measures)
#specify one factor CFA model for locus
loc_mod <- "
  loc =~ loc1 + loc2 + loc3 + loc4r + loc5 +loc6 
loc3~~loc4r "
#estimate the model using cfa
loc_mod.est <- cfa(loc_mod, data=locus, std.lv = TRUE)
#inspect the fit measures
fitmeasures(loc_mod.est)[c("rmsea","srmr","tli","cfi")]
#the fit measures were a bit weird so did this to see what the issue was - MI was real big (45.87) so then put the loc3 loc4 thing in 
modindices(loc_mod.est, sort=TRUE, minimum.value=10)
#okay slay all done that worked - i added loc3 loc4
#We should also check that all loadings are significant and > .30 - the ones with " =~" are the loadings
parameterestimates(loc_mod.est)

cope_mod <-"
cope =~ cope1 + cope2 + cope3r + cope4 + cope5 + cope6 + cope7 + cope8
cope4 ~~ cope7"
cope_mod.est <- cfa(cope_mod, missing = "ML" ,data = locus)
fitmeasures(cope_mod.est)[c("rmsea", "srmr", "tli", "cfi")]
##Modification Indices (4 and 7)
modindices(cope_mod.est, sort = TRUE)
parameterestimates(cope_mod.est)
#looks all good
anx_mod <-"
anx =~ anx1 + anx2 + anx3 + anx4
anx3 ~~ anx4"
anx_mod.est <- cfa(anx_mod, missing = "ML" ,data = locus)
fitmeasures(anx_mod.est)[c("rmsea", "srmr", "tli", "cfi")]
parameterestimates(anx_mod.est)
##Modification Indices - because anx1anx2 and anx3anx4 are the same mi, choose anx34 because they are the most conceptually similar
modindices(anx_mod.est, sort = TRUE)
fitMeasures(anx_mod.est, "df")

dep_mod <-"
dep =~ dep1 + dep2 + dep3 + dep4
dep1 ~~ dep2"
dep_mod.est <- cfa(dep_mod, missing = "ML" ,data = locus)
fitmeasures(dep_mod.est)[c("rmsea", "srmr", "tli", "cfi")]
parameterestimates(dep_mod.est)
##Modification Indices (1 and 2 are the most conceptually similar) 
modindices(dep_mod.est, sort = TRUE)
.#confused on the loadings
summary(dep_mod.est, standardized=TRUE)
#ok theyre all good
#so now specify the full SEM model and for each construct use the measurement models that i just made

# Measurement models

#model 1 - can take out cprime if needed
fullmodelA <- '
LOC =~ loc1 + loc2 + loc3 + loc4r + loc5 + loc6

COPE =~ cope1 + cope2 + cope3r + cope4 +
  cope5 + cope6 + cope7 + cope8

ANX =~ anx1 + anx2 + anx3 + anx4
DEP =~ dep1 + dep2 + dep3 + dep4

loc3 ~~ loc4r
cope4 ~~ cope7
anx3 ~~ anx4
dep1 ~~ dep2

INT =~ ANX + DEP

COPE ~ a*LOC
INT ~ b*COPE + cprime*LOC

indirect := a*b
total := cprime + (a*b) '
#now run it - request bootstrapped SEs
fullmodelA.est <- sem(fullmodelA, data = locus, std.lv = TRUE, missing = "ML",se = "bootstrap")
#inspect, request 95% CIs for parameters
summary(fullmodelA.est, ci=TRUE)
#also just to check the fits
fitmeasures(fullmodelA.est)[c("rmsea","srmr","tli","cfi")]

